# .env.example — copy to .env for local development
# In production, add these in: Vercel Dashboard → Project → Settings → Environment Variables

# ── Supabase ──────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=   # "service_role" key (NOT anon)

# ── Telegram ──────────────────────────────────────────────────────────────
BOT_TOKEN=
ADMIN_TELEGRAM_ID=        # your numeric user ID — get from @userinfobot

# ── Security ──────────────────────────────────────────────────────────────
# Strong random string — protects the /api/publish endpoint
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_TOKEN=

# ── App URL ───────────────────────────────────────────────────────────────
# Your Vercel deployment URL (used in /start bot message)
MINI_APP_URL=
